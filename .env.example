# FunSearch for CVRP - Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# API KEYS (Required for LLM features)
# =============================================================================

# Both OpenAI and Alibaba DashScope use the same 'openai' Python package,
# as DashScope provides an OpenAI-compatible API.

# Option 1: OpenAI (Recommended)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Option 2: Alibaba DashScope (Alternative - comment out OPENAI_API_KEY to use this)
# DASHSCOPE_API_KEY=your-dashscope-api-key-here

# Note: If both are set, OpenAI will be used. To use Alibaba, comment out OPENAI_API_KEY.

# =============================================================================
# LLM MODEL CONFIGURATION
# =============================================================================

# Model name to use
# For OpenAI: gpt-4, gpt-4-turbo, gpt-3.5-turbo, etc.
# For Alibaba: qwen3-max-2025-09-23, qwen-turbo, qwen-plus, etc.
# 
# Default: gpt-4 (if using OpenAI) or qwen3-max-2025-09-23 (if using Alibaba)
# OPENAI_MODEL=gpt-4

# Generation parameters
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# =============================================================================
# SEARCH CONFIGURATION
# =============================================================================

# Number of iterations for FunSearch
N_ITERATIONS=10

# Number of heuristics to generate per iteration
MIN_HEURISTICS_PER_ITER=50
MAX_HEURISTICS_PER_ITER=100

# =============================================================================
# DATASET CONFIGURATION
# =============================================================================

# Synthetic dataset sizes (number of customers)
DATASET_SIZES=20,50,100

# Random seed for reproducibility
DATASET_SEED=2026

# =============================================================================
# EVALUATION CONFIGURATION
# =============================================================================

# Early pruning threshold (skip algorithms with score > threshold * best_score)
EARLY_PRUNING_THRESHOLD=1.5

# Large scale evaluation threshold
LARGE_SCALE_THRESHOLD=4.0

# =============================================================================
# API RATE LIMITING (for stability)
# =============================================================================

# Delay between API calls (seconds)
API_CALL_DELAY=2

# Maximum retries for failed API calls
MAX_RETRIES=3

# Number of parallel API calls (reduce if hitting rate limits)
MAX_PARALLEL_CALLS=5
