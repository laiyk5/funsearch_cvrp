[LLM]
model = qwen3-max-2025-09-23
endpoint = ALI_TONGYI
openai_api_key = 
dashscope_api_key = 
openai_base_url = 
llm_temperature = 0.7

[SEARCH]
llm_max_tokens = 2000
n_iterations = 10
min_heuristics_per_iter = 50
max_heuristics_per_iter = 100
early_pruning_threshold = 1.5
large_scale_threshold = 4.0
api_call_delay = 2.0
max_retries = 4
max_parallel_calls = 5

